# Application
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3001

# Supabase PostgreSQL
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-eu-west-1.pooler.supabase.com:5432/postgres"

# Supabase Auth
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Redis
REDIS_URL="redis://localhost:6379"

# AI providers (need at least one)
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-4o
OPENAI_MODEL_CHEAP=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ANTHROPIC_API_KEY=

# Monobank API
MONOBANK_BASE_URL="https://api.monobank.ua"
MONOBANK_TOKEN=
MONOBANK_WEBHOOK_SECRET=

# Encrypts provider API tokens at rest (AES-256-GCM). 32 random bytes, base64.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# NEVER commit a real value. Rotate by re-encrypting `provider_credentials` rows.
CREDENTIAL_ENCRYPTION_KEY=

# Observability
LOG_LEVEL=info
LOG_PRETTY=true

# Feature flags
ENABLE_AI_GUARDRAILS=true
ENABLE_TWO_STEP_CONFIRMATION=true
ENABLE_RECOMMENDATION_PIPELINE=true
ENABLE_SCENARIO_SIMULATION=true
